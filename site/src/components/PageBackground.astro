---
const continents = [
  '/backgrounds/continent1_z3.webp',
  '/backgrounds/continent2_z3.webp',
  '/backgrounds/continent3_z3.webp',
];
---

<div class="page-bg" aria-hidden="true">
  <div id="page-bg-image" class="page-bg-image"></div>
  <div class="page-bg-overlay"></div>
</div>

<script is:inline define:vars={{ continents }}>
  /* Pick one of the three continent maps at random on the very first
     page in a session, then cache it in sessionStorage so every later
     navigation within the same session re-uses the same map. That
     means the image is already in the browser cache when the next
     page lands — no flicker as the browser's cross-document view
     transition crossfades, because the bg is in place before the
     new-page snapshot is taken. */
  (() => {
    const el = document.getElementById('page-bg-image');
    if (!el) return;

    let img = sessionStorage.getItem('gw-bg-img');
    const firstLoad = !img;
    if (firstLoad) {
      img = continents[Math.floor(Math.random() * continents.length)];
      sessionStorage.setItem('gw-bg-img', img);
    }
    el.style.backgroundImage = `url('${img}')`;
    if (firstLoad) {
      el.classList.add('is-ready');
    } else {
      // Subsequent navigations: skip the 500ms fade-in so the bg is
      // visible the instant the new page snapshot is taken.
      el.style.transition = 'none';
      el.style.opacity = '0.32';
    }
  })();
</script>

<style>
  .page-bg {
    position: fixed;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    overflow: hidden;
  }
  .page-bg-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
    opacity: 0;
    transition: opacity 400ms ease-out;
  }
  .page-bg-image.is-ready {
    opacity: 0.32;
  }
  .page-bg-overlay {
    position: absolute;
    inset: 0;
    /* Dark in the centre column where content sits, fading toward the
       viewport edges so the map shows through in the gutters. */
    background:
      radial-gradient(
        ellipse 55% 75% at center,
        rgba(10, 10, 10, 0.72) 0%,
        rgba(10, 10, 10, 0.6) 45%,
        rgba(10, 10, 10, 0.05) 100%
      );
  }
</style>
